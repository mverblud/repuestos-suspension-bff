{
  "name": "repuestos-suspension-bff",
  "version": "1.0.0",
  "description": "BFF para el dominio de repuestos de suspensión",
  "main": "dist/main.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "awilix": "^12.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "pino-pretty": "^13.0.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
