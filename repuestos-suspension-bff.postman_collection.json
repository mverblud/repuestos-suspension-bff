{
  "info": {
    "name": "repuestos-suspension-bff",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseURLBFF",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "ramosBaseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/auth/login",
              "host": ["{{baseURLBFF}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"cambiar-password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
      "name": "Productos",
      "item": [
        {
          "name": "Buscar productos de suspensión",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/productos",
              "host": ["{{baseURLBFF}}"],
              "path": ["productos"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigoAuto\": \"ABC123\",\n  \"marcaId\": 1,\n  \"rubroId\": 2,\n  \"cantidadRenglones\": 10\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Buscar productos Ramos (crudo)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/productos/ramos",
              "host": ["{{baseURLBFF}}"],
              "path": ["productos", "ramos"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigoAuto\": \"corsa\",\n  \"marcaId\": \"46\",\n  \"rubroId\": \"10\",\n  \"cantidadRenglones\": 500\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Buscar productos ASM (crudo)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/productos/asm",
              "host": ["{{baseURLBFF}}"],
              "path": ["productos", "asm"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"cronos\",\n  \"filters\": {\n    \"categoria\": \"AMORTIGUADORES\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
      "name": "Rubros",
      "item": [
        {
          "name": "Obtener todos los rubros",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/rubros",
              "host": ["{{baseURLBFF}}"],
              "path": ["rubros"]
            }
          }
        },
        {
          "name": "Obtener rubros habilitados",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/rubros?soloHabilitados=true",
              "host": ["{{baseURLBFF}}"],
              "path": ["rubros"],
              "query": [
                {
                  "key": "soloHabilitados",
                  "value": "true"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Autos",
      "item": [
        {
          "name": "Obtener todas las marcas y modelos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/cars",
              "host": ["{{baseURLBFF}}"],
              "path": ["cars"]
            }
          }
        },
        {
          "name": "Obtener solo habilitados",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/cars?onlyEnabled=true",
              "host": ["{{baseURLBFF}}"],
              "path": ["cars"],
              "query": [
                {
                  "key": "onlyEnabled",
                  "value": "true"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Catálogo",
      "item": [
        {
          "name": "Obtener catálogo completo",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/catalogo",
              "host": ["{{baseURLBFF}}"],
              "path": ["catalogo"]
            }
          }
        },
        {
          "name": "Obtener part por código",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/catalogo/:codigo",
              "host": ["{{baseURLBFF}}"],
              "path": ["catalogo", ":codigo"],
              "variable": [
                {
                  "key": "codigo",
                  "value": "ABC123"
                }
              ]
            }
          }
        },
        {
          "name": "Crear part",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/catalogo",
              "host": ["{{baseURLBFF}}"],
              "path": ["catalogo"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"ABC123\",\n  \"variantes\": []\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Actualizar part",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/catalogo/:codigo",
              "host": ["{{baseURLBFF}}"],
              "path": ["catalogo", ":codigo"],
              "variable": [
                {
                  "key": "codigo",
                  "value": "ABC123"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"variantes\": []\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Eliminar part",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseURLBFF}}/catalogo/:codigo",
              "host": ["{{baseURLBFF}}"],
              "path": ["catalogo", ":codigo"],
              "variable": [
                {
                  "key": "codigo",
                  "value": "ABC123"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Ramos (servicio externo)",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{ramosBaseUrl}}/auth/login",
              "host": ["{{ramosBaseUrl}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"lapassw0rd\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    }
  ]
}
