{
  "info": {
    "name": "repuestos-suspension-bff",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Productos",
      "item": [
        {
          "name": "Buscar productos de suspensión",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/productos",
              "host": ["{{baseUrl}}"],
              "path": ["productos"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigoAuto\": \"ABC123\",\n  \"marcaId\": 1,\n  \"rubroId\": 2,\n  \"cantidadRenglones\": 10\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    }
  ]
}
